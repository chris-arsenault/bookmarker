{
  "name": "bookmarker-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.29.3",
  "scripts": {
    "build": "tsc -b && vite build",
    "desktop:build": "tsc -p tsconfig.electron.json",
    "desktop:package": "pnpm run build && pnpm run desktop:build && node scripts/package-desktop.mjs",
    "desktop:typecheck": "tsc -p tsconfig.electron.json --noEmit",
    "desktop:start": "pnpm run build && pnpm run desktop:build && electron dist-electron/main.js",
    "lint": "eslint .",
    "test": "vitest run"
  },
  "dependencies": {
    "amazon-cognito-identity-js": "^6.3.16",
    "lucide-react": "^1.17.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@ahara/standards": "github:chris-arsenault/ahara-standards",
    "@eslint/js": "^9.39.3",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "4.1.8",
    "electron": "^39.2.7",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-perf": "^3.3.3",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-sonarjs": "^3.0.7",
    "globals": "^17.3.0",
    "happy-dom": "^20.10.4",
    "prettier": "^3.8.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.2.4",
    "vitest": "^4.0.15"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  }
}
